// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Data {
  id                     String     @id @default(uuid())
  first_name             String
  last_name              String
  date_of_birth          String
  email                  String     @unique
  phone_number           String     @unique
  is_member              Boolean
  is_usthb_student       Boolean
  student_id             String
  study_level            String
  field_of_study         String
  skills                 String
  area_of_interest       String
  department             Department
  completed_projects     String
  motivation             String
  school_certificate_url String
  cv_url                 String?
  linkedin               String?
  github                 String?
  created_at             DateTime   @default(now())

  @@map("data")
}

enum Department {
  technical
  communication
  digital_marketing
  external
  traing
  design
}
